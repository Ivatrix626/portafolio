---
const education = [
  {
    index: '01',
    title: 'Informática y Desarrollo',
    items: [
      {
        degree: 'Desarrollo de Aplicaciones Multiplataforma (DAM)',
        institution: 'UOC — Universitat Oberta de Catalunya',
      },
      {
        degree: 'Sistemas Microinformáticos y Redes (SMR)',
        institution: 'IES Paco Molla — Petrer',
      },
      {
        degree: 'Seguridad Informática',
        institution: 'Instituto Formación Permanente Alicante',
      },
    ],
  },
  {
    index: '02',
    title: 'Estudios Base',
    items: [
      { degree: 'Bachiller Científico', institution: 'IES — Monóvar' },
      { degree: 'Educación Secundaria Obligatoria (E.S.O.)', institution: '' },
    ],
  },
  {
    index: '03',
    title: 'Idiomas y Permisos',
    items: [
      { degree: 'Inglés', institution: 'Nivel conversacional' },
      { degree: 'Valenciano', institution: 'Nivel medio' },
      { degree: 'Carnet de conducir B y A', institution: 'Vehículo propio' },
    ],
  },
];
---

<section id="formacion" class="py-24 px-6 bg-black">
  <div class="max-w-4xl mx-auto">
    <p class="font-mono text-cyan-400/50 text-xs tracking-[0.3em] uppercase mb-3 text-center">
      // credentials.db
    </p>
    <h2 class="text-3xl font-bold text-white text-center mb-12">Formación y Certificaciones</h2>

    <div class="flex flex-col gap-3">
      {
        education.map((block) => (
          <details class="group border border-gray-700/50 rounded-xl bg-gray-900/30 overflow-hidden hover:border-gray-600/70 transition-colors">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none hover:bg-gray-800/30 transition-colors">
              <div class="flex items-center gap-4">
                <span class="font-mono text-xs text-cyan-400/50 shrink-0">[{block.index}]</span>
                <h3 class="font-semibold text-white text-base">{block.title}</h3>
              </div>
              <svg
                class="w-4 h-4 text-gray-500 shrink-0 ml-4 group-open:rotate-180 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 py-5 border-t border-gray-700/40">
              <ul class="space-y-3">
                {block.items.map((item) => (
                  <li class="flex items-start gap-2.5">
                    <span class="text-cyan-400/60 shrink-0 mt-0.5 font-mono text-sm">›</span>
                    <div>
                      <p class="text-white text-sm font-medium">{item.degree}</p>
                      {item.institution && (
                        <p class="text-gray-500 text-xs font-mono mt-0.5">{item.institution}</p>
                      )}
                    </div>
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
