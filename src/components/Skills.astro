---
const categories = [
  {
    label: 'Sistemas y Redes',
    code: '01',
    accent: 'cyan' as const,
    items: ['Mikrotik', 'Wimax', 'CGNAT', 'RADIUS', 'Linux', 'Ubiquiti', 'Cambium', 'Albentia', 'Netonix', 'Gestión de Red', 'Soporte clientes'],
  },
  {
    label: 'Desarrollo',
    code: '02',
    accent: 'green' as const,
    items: ['Python', 'Git', 'Automatización', 'IA', 'Experiencia con LLM'],
  },
  {
    label: 'Hardware',
    code: '03',
    accent: 'amber' as const,
    items: ['Mantenimiento HW/SW', 'IoT', 'Climax', 'Proview', 'Implementación de sistemas en entorno privado', 'Implementación de Domótica Privado/Empresarial'],
  },
];

const accent = {
  cyan: {
    label: 'text-cyan-400',
    topBorder: 'border-t-cyan-400/60',
    badge: 'hover:border-cyan-400/60 hover:text-cyan-300',
  },
  green: {
    label: 'text-green-400',
    topBorder: 'border-t-green-400/60',
    badge: 'hover:border-green-400/60 hover:text-green-300',
  },
  amber: {
    label: 'text-amber-400',
    topBorder: 'border-t-amber-400/60',
    badge: 'hover:border-amber-400/60 hover:text-amber-300',
  },
};
---

<section id="habilidades" class="py-24 px-6 bg-black">
  <div class="max-w-5xl mx-auto">
    <p class="font-mono text-cyan-400/50 text-xs tracking-[0.3em] uppercase mb-3 text-center">
      // core_skills.exe
    </p>
    <h2 class="text-3xl font-bold text-white text-center mb-12">Habilidades Técnicas</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
      {
        categories.map((cat) => {
          const a = accent[cat.accent];
          return (
            <div
              class={`border-t-2 ${a.topBorder} border border-gray-700/40 bg-gray-900/40 rounded-xl p-6 hover:border-gray-600/60 transition-colors`}
            >
              <div class="flex items-center gap-3 mb-5">
                <span class={`font-mono text-xs ${a.label} opacity-60`}>[{cat.code}]</span>
                <h3 class={`font-mono text-sm font-medium ${a.label} tracking-wide`}>
                  {cat.label}
                </h3>
              </div>
              <div class="flex flex-wrap gap-2">
                {cat.items.map((skill) => (
                  <span
                    class={`font-mono text-xs px-3 py-1.5 bg-gray-800/60 border border-gray-600/40 text-gray-300 rounded transition-colors ${a.badge}`}
                  >
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          );
        })
      }
    </div>
  </div>
</section>
