---
interface Props {
  t: {
    label: string;
    heading: string;
    tagline: string;
    location: string;
    copyright: string;
  };
}
const { t } = Astro.props;
---

<footer id="contacto" class="py-24 px-6 bg-gray-950 border-t border-gray-800/50">
  <div class="max-w-3xl mx-auto text-center">
    <p class="font-mono text-cyan-400/50 text-xs tracking-[0.3em] uppercase mb-3">
      {t.label}
    </p>
    <h2 class="text-3xl font-bold text-white mb-4">{t.heading}</h2>
    <p class="text-gray-400 text-lg mb-12 max-w-md mx-auto leading-relaxed">
      {t.tagline}
    </p>

    <div class="flex flex-wrap justify-center gap-4 mb-12">
      <a
        href="mailto:campos.armero.ivan@gmail.com"
        class="flex items-center gap-2 border border-gray-700/60 bg-gray-900/40 px-5 py-3 rounded-lg text-sm font-mono text-gray-300 hover:border-cyan-400/60 hover:text-cyan-400 transition-all duration-200 hover:shadow-[0_0_15px_rgba(6,182,212,0.15)]"
      >
        <svg
          class="w-4 h-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
          ></path>
        </svg>
        campos.armero.ivan@gmail.com
      </a>

      <a
        href="tel:+34744790255"
        class="flex items-center gap-2 border border-gray-700/60 bg-gray-900/40 px-5 py-3 rounded-lg text-sm font-mono text-gray-300 hover:border-green-400/60 hover:text-green-400 transition-all duration-200 hover:shadow-[0_0_15px_rgba(74,222,128,0.15)]"
      >
        <svg
          class="w-4 h-4 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"
          ></path>
        </svg>
        +34 744 790 255
      </a>

      <a
        href="https://www.linkedin.com/in/ivan-campos-armero-537266b4/"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 border border-gray-700/60 bg-gray-900/40 px-5 py-3 rounded-lg text-sm font-mono text-gray-300 hover:border-blue-400/60 hover:text-blue-400 transition-all duration-200 hover:shadow-[0_0_15px_rgba(96,165,250,0.15)]"
      >
        <svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        LinkedIn
      </a>
    </div>

    <div class="flex items-center justify-center gap-2 text-gray-600 mb-16">
      <svg
        class="w-4 h-4 shrink-0"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="1.5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
        ></path>
      </svg>
      <span class="font-mono text-xs">{t.location}</span>
    </div>

    <p class="font-mono text-xs text-gray-700">
      {t.copyright}
    </p>
  </div>
</footer>
