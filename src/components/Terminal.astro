<section id="sobre-mi" class="py-24 px-6 bg-gray-950">
  <div class="max-w-3xl mx-auto">
    <p class="font-mono text-cyan-400/50 text-xs tracking-[0.3em] uppercase mb-3 text-center">
      // sobre_mi.sh
    </p>
    <h2 class="text-3xl font-bold text-white text-center mb-12">Sobre Mí</h2>

    <div
      class="bg-[#0d1117] border border-gray-700/50 rounded-xl overflow-hidden shadow-2xl shadow-black/50"
    >
      <div
        class="flex items-center gap-1.5 px-4 py-3 bg-gray-900/70 border-b border-gray-700/50"
      >
        <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
        <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
        <span class="font-mono text-xs text-gray-500 ml-3 select-none"
          >bash — ivan@portfolio</span
        >
      </div>

      <div
        id="terminal-output"
        class="p-6 font-mono text-sm leading-relaxed min-h-36"
        aria-live="polite"
      >
      </div>
    </div>
  </div>
</section>

<script>
  const output = document.getElementById('terminal-output');
  const bio =
    'Entiendo la tecnología desde el router físico hasta el script. Combino experiencia resolviendo problemas en campo, con mi curiosidad y formación en Desarrollo de Aplicaciones Multiplataforma (DAM) y programación en Python (UOC).';

  function sleep(ms: number) {
    return new Promise((r) => setTimeout(r, ms));
  }

  async function runAnimation() {
    if (!output) return;

    await sleep(400);

    const line = document.createElement('div');
    line.className = 'flex';
    const prompt = document.createElement('span');
    prompt.className = 'text-cyan-400 shrink-0';
    prompt.textContent = 'ivan@portfolio:~$ ';
    const cmd = document.createElement('span');
    cmd.className = 'text-white';
    line.append(prompt, cmd);
    output.appendChild(line);

    for (const ch of 'whoami') {
      cmd.textContent += ch;
      await sleep(110);
    }

    await sleep(450);

    const result = document.createElement('p');
    result.className = 'text-green-400/90 mt-3 leading-relaxed';
    output.appendChild(result);

    for (const ch of bio) {
      result.textContent += ch;
      await sleep(14);
    }

    await sleep(200);

    const cursorLine = document.createElement('div');
    cursorLine.className = 'flex items-center mt-3';
    const newPrompt = document.createElement('span');
    newPrompt.className = 'text-cyan-400';
    newPrompt.textContent = 'ivan@portfolio:~$ ';
    const cursor = document.createElement('span');
    cursor.className = 'inline-block w-2 h-4 bg-cyan-400 animate-pulse';
    cursorLine.append(newPrompt, cursor);
    output.appendChild(cursorLine);
  }

  const observer = new IntersectionObserver(
    (entries) => {
      if (entries[0].isIntersecting) {
        runAnimation();
        observer.disconnect();
      }
    },
    { threshold: 0.4 }
  );

  if (output) observer.observe(output);
</script>
