---
import type { Job } from '../i18n/types';

interface Props {
  t: {
    label: string;
    heading: string;
    jobs: Job[];
  };
}
const { t } = Astro.props;
---

<section id="experiencia" class="py-24 px-6 bg-gray-950">
  <div class="max-w-4xl mx-auto">
    <p class="font-mono text-cyan-400/50 text-xs tracking-[0.3em] uppercase mb-3 text-center">
      {t.label}
    </p>
    <h2 class="text-3xl font-bold text-white text-center mb-12">{t.heading}</h2>

    <div class="flex flex-col gap-3">
      {
        t.jobs.map((job) => (
          <details class="group border border-gray-700/50 rounded-xl bg-gray-900/30 overflow-hidden hover:border-gray-600/70 transition-colors">
            <summary class="flex items-center justify-between px-6 py-4 cursor-pointer list-none [&::-webkit-details-marker]:hidden select-none hover:bg-gray-800/30 transition-colors">
              <div class="flex items-start gap-4">
                <span class="font-mono text-xs text-cyan-400/50 shrink-0 pt-0.5">
                  [{job.index}]
                </span>
                <div>
                  <h3 class="font-semibold text-white text-base leading-tight">{job.title}</h3>
                  <p class="font-mono text-xs text-gray-500 mt-0.5">{job.company}</p>
                </div>
              </div>
              <svg
                class="w-4 h-4 text-gray-500 shrink-0 ml-4 group-open:rotate-180 transition-transform duration-300"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 py-5 border-t border-gray-700/40">
              <p class="text-gray-400 text-sm mb-3">{job.summary}</p>
              <ul class="space-y-1.5">
                {job.details.map((item) => (
                  <li class="flex items-start gap-2.5 text-sm text-gray-300">
                    <span class="text-cyan-400/60 shrink-0 mt-0.5 font-mono">›</span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
