---
interface Props {
  lang: 'es' | 'en';
}
const { lang } = Astro.props;
const href = lang === 'es' ? '/en/' : '/';
const label = lang === 'es' ? 'EN' : 'ES';
---

<a
  href={href}
  class="fixed top-4 right-4 z-50 font-mono text-xs border border-gray-700/60 bg-black/80 backdrop-blur-sm px-3 py-1.5 rounded text-gray-400 hover:border-cyan-400/80 hover:text-cyan-400 transition-all duration-200"
  aria-label={lang === 'es' ? 'Switch to English' : 'Cambiar a Español'}
>
  {label}
</a>
